FROM node:20-alpine AS build

WORKDIR /app

# Copy package files
COPY client/package.json client/package-lock.json* ./

# Install deps
RUN npm install

# Copy source
COPY client/ ./

# Build
RUN npm run build

# === Serve with nginx ===
FROM nginx:alpine

# Copy built files
COPY --from=build /app/dist /usr/share/nginx/html

# Nginx config for SPA + API proxy
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
