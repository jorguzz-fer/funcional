generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth ────────────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         Role      @default(ANALYST)
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  auditLogs    AuditLog[]
  sessions     Session[]

  @@index([email])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Role {
  ADMIN
  SUPERVISOR
  ANALYST
  VIEWER
}

// ─── Referências ─────────────────────────────────────────────────────────────

model Clinica {
  id             String   @id @default(cuid())
  cnpj           String   @unique
  razaoSocial    String
  nomeFantasia   String?
  cidade         String?
  estado         String?
  prazoFaturamento Int    @default(90)
  grandeRede     Boolean  @default(false)
  ativa          Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  pedidos        Pedido[]
  ordensGagamento OrdemPagamento[]
}

model Medicamento {
  id          String   @id @default(cuid())
  codigo      String   @unique
  nome        String
  nomeCliente String   // nome aceito pelo cliente (reclassificação)
  exigeLote   Boolean  @default(false)
  tipo        TipoMedicamento @default(INFUSAO)
  ativo       Boolean  @default(true)
  createdAt   DateTime @default(now())

  pedidos     Pedido[]
}

enum TipoMedicamento {
  INFUSAO
  EXAME
  APLICACAO
}

// ─── Faturamento ─────────────────────────────────────────────────────────────

model Faturamento {
  id               String           @id @default(cuid())
  dataInicio       DateTime
  dataFechamento   DateTime
  status           StatusFaturamento @default(RASCUNHO)
  observacoes      String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  pedidos          Pedido[]
  ordensGagamento  OrdemPagamento[]
  conciliacoes     Conciliacao[]
  divergencias     Divergencia[]
  uploads          UploadArquivo[]

  @@unique([dataInicio, dataFechamento])
}

enum StatusFaturamento {
  RASCUNHO
  EM_REVISAO
  CONCILIADO
  EXPORTADO
  CONCLUIDO
}

model UploadArquivo {
  id             String        @id @default(cuid())
  faturamentoId  String
  tipo           TipoArquivo
  nomeOriginal   String
  caminho        String
  tamanhoBytes   Int
  linhasTotal    Int?
  processado     Boolean       @default(false)
  erros          Json?
  createdAt      DateTime      @default(now())

  faturamento    Faturamento   @relation(fields: [faturamentoId], references: [id])

  @@index([faturamentoId])
}

enum TipoArquivo {
  AUTORIZADOR
  PROTEUS
  RECLASSIFICACAO
  PAGAMENTO_PONTUAL
}

// ─── Pedidos (Autorizador) ────────────────────────────────────────────────────

model Pedido {
  id                    String         @id @default(cuid())
  faturamentoId         String
  clinicaId             String?

  // Campos do Autorizador
  voucher               String
  articulacaoId         String?
  codigoPaciente        String         // BR-A ou DSP (nunca nome/CPF direto — LGPD)
  nomeExame             String?
  medicamentoId         String?
  servico               String?
  procedimento          String?
  procedimentoReclassificado String?
  dataInfusao           DateTime?
  dataFinalizacaoVoucher DateTime?
  dataFaturamento       DateTime?
  ageDias               Int?
  valorUnitario         Decimal?       @db.Decimal(12, 2)
  valorTotalOrdem       Decimal?       @db.Decimal(12, 2)
  codigoOrdemPagamento  String?
  lote                  String?
  dsp                   String?        // tipo: diagnóstico ou PSP
  numeroNotaFiscal      String?
  dataEnvioNota         DateTime?
  dataEmissaoNota       DateTime?
  statusVoucher         StatusVoucher?
  statusOrdemPagamento  StatusOrdem?

  // Controle
  incluidoManualmente   Boolean        @default(false) // pagamento pontual
  excluido              Boolean        @default(false)
  motivoExclusao        String?

  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  faturamento           Faturamento    @relation(fields: [faturamentoId], references: [id])
  clinica               Clinica?       @relation(fields: [clinicaId], references: [id])
  medicamento           Medicamento?   @relation(fields: [medicamentoId], references: [id])
  conciliacao           Conciliacao?

  @@index([faturamentoId])
  @@index([voucher])
  @@index([codigoPaciente])
  @@index([clinicaId])
}

enum StatusVoucher {
  CONSULTADO
  FINALIZADO
  GLOSADO
}

enum StatusOrdem {
  AGUARDANDO_NOTA_FISCAL
  NOTA_FISCAL_EM_ANALISE
  ENVIADA_PARA_FATURAMENTO
}

// ─── Ordens de Pagamento (Proteus) ────────────────────────────────────────────

model OrdemPagamento {
  id              String    @id @default(cuid())
  faturamentoId   String
  clinicaId       String?

  codigoOrdem     String?
  numeroNotaFiscal String?
  valorTotal      Decimal?  @db.Decimal(12, 2)
  cnpj            String?
  razaoSocial     String?
  status          String?
  dataEnvio       DateTime?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  faturamento     Faturamento    @relation(fields: [faturamentoId], references: [id])
  clinica         Clinica?       @relation(fields: [clinicaId], references: [id])
  conciliacoes    Conciliacao[]

  @@index([faturamentoId])
  @@index([codigoOrdem])
}

// ─── Conciliação ─────────────────────────────────────────────────────────────

model Conciliacao {
  id              String           @id @default(cuid())
  faturamentoId   String
  pedidoId        String           @unique
  ordemId         String?

  status          StatusConciliacao @default(PENDENTE)
  valorAutorizador Decimal?        @db.Decimal(12, 2)
  valorProteus    Decimal?         @db.Decimal(12, 2)
  diferenca       Decimal?         @db.Decimal(12, 2)

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  faturamento     Faturamento      @relation(fields: [faturamentoId], references: [id])
  pedido          Pedido           @relation(fields: [pedidoId], references: [id])
  ordem           OrdemPagamento?  @relation(fields: [ordemId], references: [id])

  @@index([faturamentoId, status])
}

enum StatusConciliacao {
  PENDENTE
  OK
  ATENCAO
  RESOLVIDO
}

model Divergencia {
  id             String         @id @default(cuid())
  faturamentoId  String
  tipo           TipoDivergencia
  descricao      String
  detalhe        Json?

  valorAutorizador Decimal?     @db.Decimal(12, 2)
  valorProteus   Decimal?       @db.Decimal(12, 2)

  resolvido      Boolean        @default(false)
  resolvidoPor   String?
  resolvidoEm   DateTime?
  notasResolucao String?

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  faturamento    Faturamento    @relation(fields: [faturamentoId], references: [id])

  @@index([faturamentoId, resolvido])
}

enum TipoDivergencia {
  LINHA_FALTANTE
  VALOR_DIVERGENTE
  NF_ABREVIADA
  CNPJ_DIFERENTE
  RAZAO_SOCIAL_DIFERENTE
  LOTE_AUSENTE
  VOUCHER_SEM_FINALIZACAO
  OUTRO
}

// ─── Audit Log ───────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  entity    String
  entityId  String?
  meta      Json?
  ip        String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([entity, entityId])
}

// ─── Rate Limit ───────────────────────────────────────────────────────────────

model RateLimitHit {
  id    Int      @id @default(autoincrement())
  key   String
  hitAt DateTime @default(now())

  @@index([key, hitAt])
}
